# Server
PORT=3000
NODE_ENV=production

# Proxy (IPRoyal format: http://user:pass@host:port)
PROXY_URL=http://username:password@geo.iproyal.com:12321

# Scheduler (cron format - default: every 5 hours)
SCRAPE_CRON=0 */5 * * *

# Default search filters for scheduled scraping
DEFAULT_APARTMENT_CITY=Bordeaux
DEFAULT_APARTMENT_MAX_PRICE=1200
DEFAULT_JOB_KEYWORD=developpeur
DEFAULT_JOB_CITY=Bordeaux

# Frontend URL for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:4200
